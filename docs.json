{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TARMAC Design System",
  "favicon": "/tarmac.svg",

  "colors": {
    "primary": "#000000",
    "light": "#FFFFFF",
    "dark": "#000000"
  },

  "logo": {
    "light": "/assets/logo/light.svg",
    "dark": "/assets/logo/dark.svg"
  },

  "navigation": {
    "tabs": [
      {
        "tab": "Design System",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "Foundations",
            "pages": [
              "foundations/colors",
              "foundations/spacing",
              "foundations/tokens",
              "foundations/typography"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "components/avatar",
              "components/avatar-group",
              "components/button",
              "components/input"
            ]
          },
          {
            "group": "Patterns",
            "pages": ["patterns/forms", "patterns/tables"]
          },
          {
            "group": "Automation",
            "pages": [
              "automation/rules",
              "automation/component-schema",
              "automation/ai-generation-workflow"
            ]
          }
        ]
      }
    ]
  },

  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },

  "footer": {
    "socials": {
      "github": "https://github.com/abhishekthakur3-sketch/docs"
    }
  }
}